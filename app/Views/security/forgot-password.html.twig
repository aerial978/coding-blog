{% extends "templates/layouts/base.html.twig" %}
{% import 'templates/macros/form_fields.html.twig' as fields %}

{% block title %}{{ title }}{% endblock %}

{% block content %}
<div class="container mt-5">
  <h1 class="mb-4 text-center">Mot de passe oublié</h1>
  {% include 'templates/partials/_flashes.html.twig' with { flashes: flashes } %}

  <p class="text-muted text-center mb-4">
    Saisissez votre adresse e-mail. Si un compte existe, vous recevrez un lien de réinitialisation.
  </p>

  <form id="forgotPasswordForm" method="post" action="" novalidate data-turnstile="{{ turnstile_enabled ? '1' : '0' }}">
  <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

    {{ fields.input(
      'identifier',
      'identifier',
      'E-mail ou nom d’utilisateur',
      old.identifier|default(''),
      'text',
      true,
      'identifier_error',
      'form-control',
      { autocomplete: 'username' }
    ) }}

    {{ fields.honeypot(honeypot_name) }}

    {% include 'templates/components/turnstile_widget.html.twig' with {
        turnstile_enabled: turnstile_enabled,
        turnstile_site_key: turnstile_site_key
    } %}

    <button type="submit" class="btn btn-primary w-100">Envoyer le lien</button>

    <div class="text-center mt-3">
      <a href="{{ base_path }}login">Retour à la connexion</a>
    </div>
  </form>
</div>

{% block page_scripts %}
  <script type="module" src="{{ base_path }}public/assets/js/security/validation.forgot-password.js"></script>
  <script src="{{ base_path }}public/assets/js/security/turnstile.js" defer></script>
{% endblock %}

{% endblock %}