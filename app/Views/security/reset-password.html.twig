{% extends "templates/layouts/base.html.twig" %}
{% import 'templates/macros/form_fields.html.twig' as fields %}

{% block title %}{{ title }}{% endblock %}

{% block content %}
<div class="container mt-5">
  <h1 class="mb-4 text-center">Réinitialiser le mot de passe</h1>
  {% include 'templates/partials/_flashes.html.twig' with { flashes: flashes } %}

  <form id="resetPasswordForm" method="post" action="" novalidate data-turnstile="{{ turnstile_enabled ? '1' : '0' }}">
    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
    <input type="hidden" name="token" value="{{ token|default('') }}">

    {% include 'templates/components/password_strength.html.twig' with {
        id: 'password-field',
        input_id: 'password',
        name: 'password',
        label: 'Nouveau mot de passe',
        required: true
    } %}

    {{ fields.input(
      'password_confirm',
      'password_confirm',
      'Confirmer le nouveau mot de passe',
      '',
      'password',
      true,
      'password_confirm_error',
      'form-control',
      { autocomplete: 'new-password' }
    ) }}

    {{ fields.honeypot(honeypot_name) }}

    {% include 'templates/components/turnstile_widget.html.twig' with {
        turnstile_enabled: turnstile_enabled,
        turnstile_site_key: turnstile_site_key
    } %}

    <button type="submit" class="btn btn-primary w-100">Valider</button>

    <div class="text-center mt-3">
      <a href="{{ base_path }}login">Retour à la connexion</a>
    </div>
  </form>
</div>

{% block page_scripts %}
<script src="{{ base_path }}/public/assets/js/security/password-strength.js" defer></script>
<script type="module" src="{{ base_path }}/public/assets/js/security/validation.reset-password.js"></script>
<script src="{{ base_path }}/public/assets/js/security/turnstile.js" defer></script>
{% endblock %}

{% endblock %}
