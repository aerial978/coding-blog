{# Composant champ mot de passe + jauge Bootstrap #}
<div class="mb-3" id="{{ id|default('password-field') }}">
  <label for="{{ input_id|default('password') }}" class="form-label">
    {{ label|default('') }}
  </label>

  <div class="input-group">
    <input
      id="{{ input_id|default('password') }}"
      name="{{ name|default('password') }}"
      type="password"
      class="form-control"
      autocomplete="new-password"
      aria-describedby="{{ input_id|default('password') }}-help {{ input_id|default('password') }}-strength"
      {% if required|default(true) %}required{% endif %}
    >
    <span class="input-group-text toggle-password" role="button" aria-pressed="false" aria-label="Afficher le mot de passe">
      <i class="bi bi-eye-fill"></i>
    </span>
  </div>

  <div id="{{ input_id|default('password') }}-help" class="form-text mt-2">
    Le mot de passe doit contenir au minimum :
  </div>

  <ul class="list-unstyled row gx-3 gy-1 pw-criteria mt-1" aria-live="polite">
    <li class="col-6 d-flex align-items-center gap-2 text-danger" data-check="lower">
      <span class="pw-dot"></span> Une minuscule
    </li>
    <li class="col-6 d-flex align-items-center gap-2 text-danger" data-check="upper">
      <span class="pw-dot"></span> Une majuscule
    </li>
    <li class="col-6 d-flex align-items-center gap-2 text-danger" data-check="digit">
      <span class="pw-dot"></span> Un chiffre
    </li>
    <li class="col-6 d-flex align-items-center gap-2 text-danger" data-check="special">
      <span class="pw-dot"></span> Un caractère spécial
    </li>
    <li class="col-6 d-flex align-items-center gap-2 text-danger" data-check="length">
      <span class="pw-dot"></span> 12 caractères
    </li>
  </ul>

  <div class="progress mt-3" role="progressbar" aria-valuemin="0" aria-valuemax="100"
      aria-describedby="{{ input_id|default('password') }}-strength">
    <div class="progress-bar" style="width: 0%"></div>
  </div>

  <div id="{{ input_id|default('password') }}-strength" class="d-flex justify-content-end small mt-2">
    <span class="pw-level">Faible</span>
  </div>

  <p class="visually-hidden pw-aria"></p>
</div>
